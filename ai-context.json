{
  "$schema": "./ai-context.schema.json",
  "schema_version": "1.0",
  "project": {
    "name": "go-knifer",
    "module": "github.com/imajinyun/go-knifer",
    "language": "go",
    "go_version": ">=1.25",
    "layout": "public v* facade packages delegate to internal/* implementation packages"
  },
  "commands": {
    "environment_diagnostics": {
      "cmd": "make doctor",
      "safe_for_agent_auto_run": true,
      "writes_workspace": false,
      "writes_git_config": false,
      "network_required": false,
      "risk_level": "low",
      "notes": "Reports local Go/tooling/Git state without modifying repository files."
    },
    "worktree_check": {
      "cmd": "make worktree-check",
      "safe_for_agent_auto_run": true,
      "writes_workspace": false,
      "writes_git_config": false,
      "network_required": false,
      "risk_level": "low",
      "notes": "Fails when unrelated untracked Go files may pollute tests or commits. Use SKIP_WORKTREE_CHECK=1 only when intentionally excluding those files."
    },
    "test": {
      "cmd": "make test",
      "safe_for_agent_auto_run": true,
      "writes_workspace": false,
      "writes_git_config": false,
      "network_required": false,
      "risk_level": "low",
      "notes": "Runs unit tests for PKGS, defaulting to ./...."
    },
    "quick_check": {
      "cmd": "make quick-check",
      "safe_for_agent_auto_run": true,
      "writes_workspace": false,
      "writes_git_config": false,
      "network_required": false,
      "risk_level": "low",
      "notes": "Fast local gate; includes worktree-check, module verification, vet, architecture, tests, API snapshot, documentation checks, AI context, and whitespace diff checks."
    },
    "agent_check": {
      "cmd": "make agent-check",
      "safe_for_agent_auto_run": true,
      "writes_workspace": false,
      "writes_git_config": false,
      "network_required": false,
      "risk_level": "low",
      "notes": "Default AI/Agent-safe validation entrypoint; delegates to quick-check and detects security-sensitive diffs."
    },
    "security_sensitive_diff": {
      "cmd": "make security-sensitive-diff",
      "safe_for_agent_auto_run": true,
      "writes_workspace": false,
      "writes_git_config": false,
      "network_required": false,
      "risk_level": "low",
      "notes": "Detects base, staged, unstaged, untracked, and deleted changed files under security-sensitive public facades and their internal implementations."
    },
    "change_policy_check": {
      "cmd": "make change-policy-check",
      "safe_for_agent_auto_run": true,
      "writes_workspace": false,
      "writes_git_config": false,
      "network_required": false,
      "risk_level": "low",
      "notes": "Detects base, staged, unstaged, untracked, and deleted changed file categories and maps them to change_type_policies."
    },
    "agent_evidence": {
      "cmd": "make agent-evidence",
      "safe_for_agent_auto_run": true,
      "writes_workspace": false,
      "writes_git_config": false,
      "network_required": false,
      "risk_level": "low",
      "creates_artifacts": ["/tmp/go-knifer-agent-validation.json"],
      "notes": "Writes machine-readable Agent validation evidence outside the repository root, including base ref, deleted-file-aware diff metadata, detected policies, required commands, and command attestations."
    },
    "agent_evidence_check": {
      "cmd": "make agent-evidence-check",
      "safe_for_agent_auto_run": true,
      "writes_workspace": false,
      "writes_git_config": false,
      "network_required": false,
      "risk_level": "low",
      "reads_artifacts": ["/tmp/go-knifer-agent-validation.json"],
      "notes": "Validates Agent evidence JSON schema, diff metadata, policy references, command references, command attestation coverage, risk calculation, and embedded check consistency."
    },
    "agent_full_check": {
      "cmd": "make agent-full-check COVERAGE_FILE=/tmp/go-knifer-coverage.out",
      "safe_for_agent_auto_run": true,
      "writes_workspace": false,
      "writes_git_config": false,
      "network_required": true,
      "risk_level": "medium",
      "creates_artifacts": ["/tmp/go-knifer-coverage.out"],
      "notes": "Full AI/Agent validation entrypoint; runs race coverage, lint, and vulnerability checks."
    },
    "agent_security_check": {
      "cmd": "make agent-security-check",
      "safe_for_agent_auto_run": true,
      "writes_workspace": false,
      "writes_git_config": false,
      "network_required": true,
      "risk_level": "medium",
      "notes": "AI/Agent security validation entrypoint; runs lint and govulncheck."
    },
    "ci_test": {
      "cmd": "make ci-test COVERAGE_FILE=/tmp/go-knifer-coverage.out",
      "safe_for_agent_auto_run": true,
      "writes_workspace": false,
      "writes_git_config": false,
      "network_required": false,
      "risk_level": "medium",
      "creates_artifacts": ["/tmp/go-knifer-coverage.out"],
      "notes": "Local reproduction of the GitHub Actions test job without creating coverage artifacts in the repository root."
    },
    "ci_agent_governance": {
      "cmd": "make ci-agent-governance",
      "safe_for_agent_auto_run": true,
      "writes_workspace": false,
      "writes_git_config": false,
      "network_required": false,
      "risk_level": "low",
      "creates_artifacts": ["/tmp/go-knifer-agent-validation.json"],
      "notes": "CI Agent governance gate; detects changed policies against AGENT_CHANGE_BASE_REF and emits validation evidence."
    },
    "full_check": {
      "cmd": "make check COVERAGE_FILE=/tmp/go-knifer-coverage.out",
      "safe_for_agent_auto_run": true,
      "writes_workspace": false,
      "writes_git_config": false,
      "network_required": true,
      "risk_level": "medium",
      "creates_artifacts": ["/tmp/go-knifer-coverage.out"],
      "notes": "Full local pre-push gate; govulncheck may require vulnerability database access."
    },
    "security_check": {
      "cmd": "make security-check",
      "safe_for_agent_auto_run": true,
      "writes_workspace": false,
      "writes_git_config": false,
      "network_required": true,
      "risk_level": "medium",
      "notes": "Runs golangci-lint and govulncheck."
    },
    "release_check": {
      "cmd": "make release-check COVERAGE_FILE=/tmp/go-knifer-coverage.out",
      "safe_for_agent_auto_run": true,
      "writes_workspace": false,
      "writes_git_config": false,
      "network_required": true,
      "risk_level": "medium",
      "creates_artifacts": ["/tmp/go-knifer-coverage.out"],
      "notes": "Release readiness gate; runs full local checks plus CI workflow governance validation."
    },
    "release_notes_check": {
      "cmd": "make release-notes-check",
      "safe_for_agent_auto_run": true,
      "writes_workspace": false,
      "writes_git_config": false,
      "network_required": false,
      "risk_level": "low",
      "notes": "Validates CHANGELOG.md release-note structure and, when RELEASE_VERSION is set, verifies the tagged version has explicit release notes."
    },
    "coverage_profile": {
      "cmd": "make coverage-profile COVERAGE_FILE=/tmp/go-knifer-coverage.out",
      "safe_for_agent_auto_run": true,
      "writes_workspace": false,
      "writes_git_config": false,
      "network_required": false,
      "risk_level": "medium",
      "creates_artifacts": ["/tmp/go-knifer-coverage.out"],
      "notes": "Generates a race/shuffle coverage profile outside the repository root."
    },
    "coverage_check": {
      "cmd": "make coverage-check COVERAGE_FILE=/tmp/go-knifer-coverage.out",
      "safe_for_agent_auto_run": true,
      "writes_workspace": false,
      "writes_git_config": false,
      "network_required": false,
      "risk_level": "medium",
      "reads_artifacts": ["/tmp/go-knifer-coverage.out"],
      "notes": "Requires a fresh coverage profile at the configured path and verifies security-sensitive packages have coverage data."
    },
    "api_check": {
      "cmd": "make api-check",
      "safe_for_agent_auto_run": true,
      "writes_workspace": false,
      "writes_git_config": false,
      "network_required": false,
      "risk_level": "low",
      "notes": "Checks that docs/api/exports.txt is current."
    },
    "tools_check": {
      "cmd": "make tools-check",
      "safe_for_agent_auto_run": true,
      "writes_workspace": false,
      "writes_git_config": false,
      "network_required": false,
      "risk_level": "low",
      "notes": "Checks that docs/api/tools.json is current."
    },
    "docs_check": {
      "cmd": "make docs-check",
      "safe_for_agent_auto_run": true,
      "writes_workspace": false,
      "writes_git_config": false,
      "network_required": false,
      "risk_level": "low",
      "notes": "Checks generated documentation artifacts and facade quickstart cookbook structure."
    },
    "docs_quickstart_check": {
      "cmd": "make docs-quickstart-check",
      "safe_for_agent_auto_run": true,
      "writes_workspace": false,
      "writes_git_config": false,
      "network_required": false,
      "risk_level": "low",
      "notes": "Validates that every public facade has a standardized docs/doc quickstart with required cookbook sections."
    },
    "ai_context_check": {
      "cmd": "make ai-context-check",
      "safe_for_agent_auto_run": true,
      "writes_workspace": false,
      "writes_git_config": false,
      "network_required": false,
      "risk_level": "low",
      "notes": "Validates ai-context.json schema, command side-effect metadata, facade inventory, and security-sensitive package references."
    },
    "ci_workflow_check": {
      "cmd": "make ci-workflow-check",
      "safe_for_agent_auto_run": true,
      "writes_workspace": false,
      "writes_git_config": false,
      "network_required": false,
      "risk_level": "low",
      "notes": "Validates GitHub Actions workflow governance invariants declared in ai-context.json."
    },
    "generate": {
      "cmd": "make generate",
      "safe_for_agent_auto_run": false,
      "requires_user_consent": true,
      "writes_workspace": true,
      "writes_git_config": false,
      "network_required": false,
      "risk_level": "high",
      "writes_files": ["docs/api/exports.txt", "docs/api/tools.json", "docs/api/tools.md"],
      "notes": "Runs repository go:generate directives and documentation generation targets. Only run after confirming generated output is expected."
    },
    "docs_update": {
      "cmd": "make docs-gen",
      "safe_for_agent_auto_run": false,
      "requires_user_consent": true,
      "writes_workspace": true,
      "writes_git_config": false,
      "network_required": false,
      "risk_level": "high",
      "writes_files": ["docs/api/tools.json", "docs/api/tools.md"],
      "notes": "Regenerates documentation artifacts that are derived from source code. Only run after confirming generated output is expected."
    },
    "api_update": {
      "cmd": "UPDATE_API=1 make api-check",
      "safe_for_agent_auto_run": false,
      "requires_user_consent": true,
      "writes_workspace": true,
      "writes_git_config": false,
      "network_required": false,
      "risk_level": "high",
      "writes_files": ["docs/api/exports.txt"],
      "notes": "Only run after confirming an intentional public API change."
    },
    "tools_update": {
      "cmd": "make tools-gen",
      "safe_for_agent_auto_run": false,
      "requires_user_consent": true,
      "writes_workspace": true,
      "writes_git_config": false,
      "network_required": false,
      "risk_level": "high",
      "writes_files": ["docs/api/tools.json", "docs/api/tools.md"],
      "notes": "Only run after confirming intentional facade, doc comment, or Example changes."
    },
    "install_hooks": {
      "cmd": "make install-hooks",
      "safe_for_agent_auto_run": false,
      "requires_user_consent": true,
      "writes_workspace": false,
      "writes_git_config": true,
      "network_required": false,
      "risk_level": "high",
      "notes": "Modifies local Git config core.hooksPath and file executable bits; do not run unless explicitly requested."
    },
    "uninstall_hooks": {
      "cmd": "make uninstall-hooks",
      "safe_for_agent_auto_run": false,
      "requires_user_consent": true,
      "writes_workspace": false,
      "writes_git_config": true,
      "network_required": false,
      "risk_level": "high",
      "notes": "Modifies local Git config; do not run unless explicitly requested."
    },
    "bench_core": {
      "cmd": "make bench-core",
      "safe_for_agent_auto_run": true,
      "writes_workspace": false,
      "writes_git_config": false,
      "network_required": false,
      "risk_level": "low",
      "notes": "Runs benchmark baselines for core packages; output is evidence, not a performance claim."
    },
    "bench_facade": {
      "cmd": "make bench-facade",
      "safe_for_agent_auto_run": true,
      "writes_workspace": false,
      "writes_git_config": false,
      "network_required": false,
      "risk_level": "low",
      "notes": "Runs benchmark baselines for facade packages; output is evidence, not a performance claim."
    },
    "bench_codec": {
      "cmd": "make bench-codec",
      "safe_for_agent_auto_run": true,
      "writes_workspace": false,
      "writes_git_config": false,
      "network_required": false,
      "risk_level": "low",
      "notes": "Runs JSON/XML benchmark baselines; output is evidence, not a performance claim."
    }
  },
  "change_type_policies": {
    "bug_fix": {
      "required_commands": ["change_policy_check", "agent_check", "agent_evidence", "agent_evidence_check"],
      "coverage_required": false,
      "security_review_required": false,
      "notes": "Default policy for localized behavior fixes. Add coverage_profile and coverage_check when the fix is non-trivial."
    },
    "public_api": {
      "required_commands": ["change_policy_check", "agent_full_check", "api_check", "tools_check", "coverage_check", "agent_evidence", "agent_evidence_check"],
      "requires_user_consent_commands": ["api_update", "tools_update"],
      "coverage_required": true,
      "security_review_required": false,
      "notes": "Public API additions or breaking changes must keep the API snapshot, tools catalog, and coverage evidence current."
    },
    "internal_refactor": {
      "required_commands": ["change_policy_check", "agent_check", "coverage_profile", "coverage_check", "agent_evidence", "agent_evidence_check"],
      "coverage_required": true,
      "security_review_required": false,
      "notes": "Internal refactors should preserve behavior and coverage while passing architecture gates."
    },
    "documentation": {
      "required_commands": ["change_policy_check", "agent_check", "docs_check", "agent_evidence", "agent_evidence_check"],
      "requires_user_consent_commands": ["docs_update"],
      "coverage_required": false,
      "security_review_required": false,
      "notes": "Documentation-only changes should still pass metadata, API snapshot, tools catalog, and whitespace checks."
    },
    "ci_governance": {
      "required_commands": ["change_policy_check", "agent_check", "ai_context_check", "docs_check", "agent_evidence", "agent_evidence_check"],
      "coverage_required": false,
      "security_review_required": false,
      "notes": "CI and governance changes must keep Makefile targets and AI metadata synchronized."
    },
    "security_sensitive": {
      "required_commands": ["change_policy_check", "security_sensitive_diff", "agent_full_check", "agent_security_check", "agent_evidence", "agent_evidence_check"],
      "coverage_required": true,
      "security_review_required": true,
      "notes": "Changes touching security-sensitive packages must include regression coverage and security validation."
    },
    "dependency_change": {
      "required_commands": ["change_policy_check", "agent_check", "agent_security_check", "agent_evidence", "agent_evidence_check"],
      "coverage_required": false,
      "security_review_required": true,
      "notes": "Dependency changes must verify module integrity and vulnerability exposure."
    }
  },
  "git_hooks": {
    "optional": true,
    "install": "make install-hooks",
    "uninstall": "make uninstall-hooks",
    "pre_commit": "make quick-check",
    "pre_push": "make full-check COVERAGE_FILE=/tmp/go-knifer-coverage.out"
  },
  "ci_workflows": {
    "tool_versions": {
      "go_1_25_patch": "1.25.11",
      "golangci_lint": "v2.12.2"
    },
    "github_actions": {
      "go": {
        "path": ".github/workflows/go.yml",
        "required_jobs": ["agent-governance", "test", "lint", "govulncheck", "codeql"],
        "agent_governance": {
          "required_commands": ["make ci-agent-governance"],
          "required_env": ["AGENT_CHANGE_BASE_REF", "AGENT_EVIDENCE_FILE"],
          "required_artifacts": ["agent-validation-evidence"]
        }
      },
      "release": {
        "path": ".github/workflows/release.yml",
        "required_jobs": ["release"],
        "agent_governance": {
          "required_commands": ["make release-check"],
          "required_env": [],
          "required_artifacts": []
        }
      }
    }
  },
  "architecture_rules": [
    "Public v* packages are thin facades over internal/* implementations.",
    "Public v* packages must not import other public v* packages.",
    "Internal packages must not import public v* packages.",
    "Every public v* package directory must contain doc.go with a package comment.",
    "Production panic is allowed only for explicit MustXxx/PanicXxx APIs or documented compatibility cases.",
    "Intentional public API changes must update docs/api/exports.txt with UPDATE_API=1 make api-check.",
    "Intentional facade, doc comment, or Example changes must update docs/api/tools.json with make tools-gen."
  ],
  "generated_artifacts": {
    "api_snapshot": {
      "path": "docs/api/exports.txt",
      "generator_command": "api_update",
      "check_command": "api_check"
    },
    "tools_catalog_json": {
      "path": "docs/api/tools.json",
      "generator_command": "tools_update",
      "check_command": "tools_check"
    },
    "tools_catalog_markdown": {
      "path": "docs/api/tools.md",
      "generator_command": "docs_update",
      "check_command": "docs_check"
    }
  },
  "coverage_gates": {
    "repository_threshold": 75.2,
    "security_sensitive_min_threshold": 80.0,
    "package_thresholds": {
      "github.com/imajinyun/go-knifer/vbean": 90.0,
      "github.com/imajinyun/go-knifer/vcache": 90.0,
      "github.com/imajinyun/go-knifer/vconf": 75.0,
      "github.com/imajinyun/go-knifer/vcrypto": 70.0,
      "github.com/imajinyun/go-knifer/vdate": 85.0,
      "github.com/imajinyun/go-knifer/vfile": 85.0,
      "github.com/imajinyun/go-knifer/vform": 90.0,
      "github.com/imajinyun/go-knifer/vhttp": 75.0,
      "github.com/imajinyun/go-knifer/vimg": 90.0,
      "github.com/imajinyun/go-knifer/vresty": 65.0,
      "github.com/imajinyun/go-knifer/vset": 80.0,
      "github.com/imajinyun/go-knifer/vsys": 90.0,
      "github.com/imajinyun/go-knifer/vurl": 80.0,
      "github.com/imajinyun/go-knifer/vzip": 80.0,
      "github.com/imajinyun/go-knifer/internal/bean": 75.0,
      "github.com/imajinyun/go-knifer/internal/db": 60.0,
      "github.com/imajinyun/go-knifer/internal/httpx/http": 75.0,
      "github.com/imajinyun/go-knifer/internal/httpx/internal/shared": 80.0,
      "github.com/imajinyun/go-knifer/internal/httpx/resty": 75.0,
      "github.com/imajinyun/go-knifer/internal/mask": 95.0,
      "github.com/imajinyun/go-knifer/internal/net": 80.0,
      "github.com/imajinyun/go-knifer/internal/obj": 90.0,
      "github.com/imajinyun/go-knifer/internal/template": 95.0,
      "github.com/imajinyun/go-knifer/internal/url": 80.0,
      "github.com/imajinyun/go-knifer/internal/validator": 100.0
    }
  },
  "public_facades": [
    { "package": "vai", "domain": "AI adapters", "internal": "internal/ai" },
    { "package": "vbean", "domain": "struct/map mapping", "internal": "internal/bean" },
    { "package": "vblf", "domain": "bloom filter", "internal": "internal/bloomfilter" },
    { "package": "vbool", "domain": "booleans", "internal": "internal/boolean" },
    { "package": "vcache", "domain": "caches", "internal": "internal/cache" },
    { "package": "vcli", "domain": "CLI helpers", "internal": "internal/cli" },
    { "package": "vcodec", "domain": "Base64/Hex encoding", "internal": "internal/codec" },
    { "package": "vconf", "domain": "configuration", "internal": "internal/conf" },
    { "package": "vconv", "domain": "type conversion", "internal": "internal/conv" },
    { "package": "vcron", "domain": "cron scheduling", "internal": "internal/cron" },
    { "package": "vcrypto", "domain": "cryptography and digests", "internal": "internal/crypto" },
    { "package": "vcsv", "domain": "CSV", "internal": "internal/csvx" },
    { "package": "vdate", "domain": "date/time", "internal": "internal/date" },
    { "package": "vdb", "domain": "database/SQL", "internal": "internal/db" },
    { "package": "vdfa", "domain": "DFA word-tree matching", "internal": "internal/dfa" },
    { "package": "verr", "domain": "error handling", "internal": "internal/errx" },
    { "package": "vfile", "domain": "file and IO", "internal": "internal/file" },
    { "package": "vform", "domain": "form/input validation", "internal": "internal/validator" },
    { "package": "vftp", "domain": "FTP adapters", "internal": "internal/ftp" },
    { "package": "vhash", "domain": "non-cryptographic hashes", "internal": "internal/hash" },
    { "package": "vhttp", "domain": "HTTP", "internal": "internal/httpx" },
    { "package": "vid", "domain": "generated IDs", "internal": "internal/id" },
    { "package": "vident", "domain": "identity numbers", "internal": "internal/identity" },
    { "package": "vimg", "domain": "images/captchas", "internal": "internal/imgx" },
    { "package": "vjob", "domain": "job orchestration", "internal": "internal/job" },
    { "package": "vjson", "domain": "JSON", "internal": "internal/json" },
    { "package": "vjwt", "domain": "JWT", "internal": "internal/jwt" },
    { "package": "vlog", "domain": "logging", "internal": "internal/log" },
    { "package": "vmail", "domain": "email/SMTP", "internal": "internal/mail" },
    { "package": "vmap", "domain": "maps", "internal": "internal/maps" },
    { "package": "vmask", "domain": "data masking", "internal": "internal/mask" },
    { "package": "vnet", "domain": "IP/port/network", "internal": "internal/net" },
    { "package": "vnum", "domain": "numeric helpers", "internal": "internal/num" },
    { "package": "vobj", "domain": "object helpers", "internal": "internal/obj" },
    { "package": "vpass", "domain": "password strength", "internal": "internal/pass" },
    { "package": "vhan", "domain": "Han text romanization adapters", "internal": "internal/pinyin" },
    { "package": "vpoi", "domain": "office documents", "internal": "internal/poi" },
    { "package": "vrand", "domain": "randomness", "internal": "internal/rand" },
    { "package": "vref", "domain": "reflection", "internal": "internal/ref" },
    { "package": "vregex", "domain": "regular expressions", "internal": "internal/regex" },
    { "package": "vresty", "domain": "HTTP Resty", "internal": "internal/httpx/resty" },
    { "package": "vsem", "domain": "semaphores", "internal": "internal/semaphore" },
    { "package": "vset", "domain": "sets", "internal": "internal/sets" },
    { "package": "vskt", "domain": "sockets", "internal": "internal/socket" },
    { "package": "vslice", "domain": "slices", "internal": "internal/slice" },
    { "package": "vssh", "domain": "SSH/SFTP adapters", "internal": "internal/ssh" },
